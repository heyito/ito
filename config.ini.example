[OpenAI]
api_key = YOUR_OPENAI_API_KEY_HERE

[ASR]
# provider = openai_api or faster_whisper
provider = faster_whisper
model = whisper-1

# -- Settings for faster_whisper --
# Options: tiny, tiny.en, base, base.en, small, small.en, medium, medium.en, large-v1, large-v2, large-v3
# Using large-v3 for best accuracy
local_model_size = large-v3
# Device: cpu, cuda, auto (Let faster-whisper decide)
device = auto
# Compute type: float16 (GPU default), int8 (CPU/GPU, faster, quantized), float32 (CPU)
# Using float16 for best accuracy on GPU, or int8 for CPU
compute_type = float16

[LLM]
# Provider options: 'openai_api' or 'local_llm'
provider = local_llm

# OpenAI API settings (only used if provider = openai_api)
api_key = YOUR_OPENAI_API_KEY_HERE
model = gpt-4.1

# Local model settings (only used if provider = local_llm)
local_model = google/gemma-3-2b-it
quantization = 8
max_tokens = 2000
temperature = 0.7

[Audio]
sample_rate = 16000
channels = 1
# device_index = # Optional: specify input device index if default is wrong. Find using utils/list_audio_devices.py

[VAD]
# Enable automatic silence detection to stop recording
enabled = true
# VAD aggressiveness (0-3). Higher values are more aggressive in classifying non-speech
aggressiveness = 1
# Duration of silence in milliseconds to trigger stop
silence_duration_ms = 1000
# Internal frame duration for VAD processing (ms). Must be 10, 20, or 30.
frame_duration_ms = 30

[Output]
# method = typewrite or clipboard
method = typewrite

[Hotkeys]
start_recording_hotkey = f9
# Example alternatives:
# start_recording_hotkey = ctrl+shift+k